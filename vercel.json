{
  "version": 2,
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/",
      "destination": "https://office.ziziyi.com",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
